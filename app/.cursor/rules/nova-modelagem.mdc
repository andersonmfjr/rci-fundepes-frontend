-- =====================================================
-- TABELAS DE APOIO/LOOKUP
-- =====================================================

-- Tabela: tipos_usuarios
CREATE TABLE tipos_usuarios (
id SERIAL PRIMARY KEY,
descricao VARCHAR(100) NOT NULL UNIQUE
);

-- Tabela: tipos_unidades
CREATE TABLE tipos_unidades (
id SERIAL PRIMARY KEY,
descricao VARCHAR(100) NOT NULL UNIQUE
);

-- Tabela: tipos_contratos
CREATE TABLE tipos_contratos (
id SERIAL PRIMARY KEY,
descricao VARCHAR(100) NOT NULL UNIQUE
);

-- Tabela: tipos_financiadores (NOVA)
CREATE TABLE tipos_financiadores (
id SERIAL PRIMARY KEY,
descricao VARCHAR(100) NOT NULL UNIQUE
);

-- =====================================================
-- TABELAS PRINCIPAIS
-- =====================================================

-- Tabela: bancos
CREATE TABLE bancos (
id SERIAL PRIMARY KEY,
codigo VARCHAR(10) NOT NULL UNIQUE,
nome VARCHAR(200) NOT NULL
);

-- Tabela: financiadores (ALTERADA - adicionado id_tipo_financiador)
CREATE TABLE financiadores (
id SERIAL PRIMARY KEY,
id_tipo_financiador INTEGER NOT NULL,
nome VARCHAR(200) NOT NULL,
tipo VARCHAR(100),
cnpj VARCHAR(18) UNIQUE,
CONSTRAINT fk_financiadores_tipo
FOREIGN KEY (id_tipo_financiador) REFERENCES tipos_financiadores(id)
ON DELETE RESTRICT ON UPDATE CASCADE
);

-- Tabela: unidades_academicas (ALTERADA - estrutura hierárquica, sem id_instituicao)
CREATE TABLE unidades_academicas (
id SERIAL PRIMARY KEY,
id_unidade_pai INTEGER,
id_tipo_unidade INTEGER NOT NULL,
nome VARCHAR(200) NOT NULL,
sigla VARCHAR(20),
cnpj VARCHAR(18) UNIQUE,
CONSTRAINT fk_unidades_pai
FOREIGN KEY (id_unidade_pai) REFERENCES unidades_academicas(id)
ON DELETE RESTRICT ON UPDATE CASCADE,
CONSTRAINT fk_unidades_tipo
FOREIGN KEY (id_tipo_unidade) REFERENCES tipos_unidades(id)
ON DELETE RESTRICT ON UPDATE CASCADE
);

-- Tabela: usuarios
CREATE TABLE usuarios (
id SERIAL PRIMARY KEY,
id_unidade INTEGER NOT NULL,
nome VARCHAR(200) NOT NULL,
email VARCHAR(150) UNIQUE NOT NULL,
CONSTRAINT fk_usuarios_unidade
FOREIGN KEY (id_unidade) REFERENCES unidades_academicas(id)
ON DELETE RESTRICT ON UPDATE CASCADE
);

-- Tabela: contas_bancarias
CREATE TABLE contas_bancarias (
id SERIAL PRIMARY KEY,
id_unidade INTEGER NOT NULL,
id_banco INTEGER NOT NULL,
agencia VARCHAR(10) NOT NULL,
numero VARCHAR(20) NOT NULL,
CONSTRAINT fk_contas_unidade
FOREIGN KEY (id_unidade) REFERENCES unidades_academicas(id)
ON DELETE RESTRICT ON UPDATE CASCADE,
CONSTRAINT fk_contas_banco
FOREIGN KEY (id_banco) REFERENCES bancos(id)
ON DELETE RESTRICT ON UPDATE CASCADE,
CONSTRAINT uk_conta_bancaria
UNIQUE (id_banco, agencia, numero)
);

-- Tabela: contratos (ALTERADA - conecta com unidades_academicas em vez de instituicoes)
CREATE TABLE contratos (
id SERIAL PRIMARY KEY,
id_unidade_academica INTEGER NOT NULL,
id_financiador INTEGER NOT NULL,
id_tipo_contrato INTEGER NOT NULL,
valor_total DECIMAL(15,2) NOT NULL CHECK (valor_total >= 0),
vigencia_inicio DATE NOT NULL,
vigencia_fim DATE NOT NULL,
validado BOOLEAN DEFAULT FALSE,
nome VARCHAR(255) NOT NULL,
descricao VARCHAR(255) NOT NULL,
data_criacao TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
data_atualizacao TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
CONSTRAINT fk_contratos_unidade
FOREIGN KEY (id_unidade_academica) REFERENCES unidades_academicas(id)
ON DELETE RESTRICT ON UPDATE CASCADE,
CONSTRAINT fk_contratos_financiador
FOREIGN KEY (id_financiador) REFERENCES financiadores(id)
ON DELETE RESTRICT ON UPDATE CASCADE,
CONSTRAINT fk_contratos_tipo
FOREIGN KEY (id_tipo_contrato) REFERENCES tipos_contratos(id)
ON DELETE RESTRICT ON UPDATE CASCADE,
CONSTRAINT ck_vigencia
CHECK (vigencia_fim >= vigencia_inicio)
);

-- Tabela: distribuicao_rci
CREATE TABLE distribuicao_rci (
id SERIAL PRIMARY KEY,
id_unidade INTEGER NOT NULL,
id_contrato INTEGER NOT NULL,
percentual DECIMAL(5,2) NOT NULL CHECK (percentual >= 0 AND percentual <= 100),
valor_base_calculo DECIMAL(15,2) NOT NULL CHECK (valor_base_calculo >= 0),
validado BOOLEAN DEFAULT FALSE,
data_criacao TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
CONSTRAINT fk_distribuicao_unidade
FOREIGN KEY (id_unidade) REFERENCES unidades_academicas(id)
ON DELETE RESTRICT ON UPDATE CASCADE,
CONSTRAINT fk_distribuicao_contrato
FOREIGN KEY (id_contrato) REFERENCES contratos(id)
ON DELETE CASCADE ON UPDATE CASCADE,
CONSTRAINT uk_distribuicao_contrato_unidade
UNIQUE (id_contrato, id_unidade)
);

-- Tabela: transferencias (ALTERADA - conecta com distribuicao_rci em vez de contratos)
CREATE TABLE transferencias (
id SERIAL PRIMARY KEY,
id_conta_origem INTEGER NOT NULL,
id_conta_destino INTEGER NOT NULL,
id_distribuicao_rci INTEGER NOT NULL,
data DATE NOT NULL,
valor DECIMAL(15,2) NOT NULL CHECK (valor > 0),
observacao TEXT,
validada BOOLEAN DEFAULT FALSE,
data_criacao TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
CONSTRAINT fk_transferencias_origem
FOREIGN KEY (id_conta_origem) REFERENCES contas_bancarias(id)
ON DELETE RESTRICT ON UPDATE CASCADE,
CONSTRAINT fk_transferencias_destino
FOREIGN KEY (id_conta_destino) REFERENCES contas_bancarias(id)
ON DELETE RESTRICT ON UPDATE CASCADE,
CONSTRAINT fk_transferencias_distribuicao
FOREIGN KEY (id_distribuicao_rci) REFERENCES distribuicao_rci(id)
ON DELETE RESTRICT ON UPDATE CASCADE,
CONSTRAINT ck_contas_diferentes
CHECK (id_conta_origem != id_conta_destino)
);

-- Tabela: aditivos_contratos
CREATE TABLE aditivos_contratos (
id SERIAL PRIMARY KEY,
id_contrato INTEGER NOT NULL,
data DATE NOT NULL,
novo_total DECIMAL(15,2) NOT NULL CHECK (novo_total >= 0),
validado BOOLEAN DEFAULT FALSE,
descricao TEXT,
data_criacao TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
CONSTRAINT fk_aditivos_contrato
FOREIGN KEY (id_contrato) REFERENCES contratos(id)
ON DELETE CASCADE ON UPDATE CASCADE
);

