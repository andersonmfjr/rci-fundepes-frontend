-- =====================================================
-- VIEWS ÚTEIS PARA O DASHBOARD
-- =====================================================

-- View: Resumo de contratos por situação
CREATE VIEW vw_contratos_situacao AS
SELECT
    tc.descricao as tipo_contrato,
    CASE
        WHEN c.vigencia_fim < CURRENT_DATE THEN 'Finalizado'
        WHEN c.vigencia_inicio > CURRENT_DATE THEN 'Não Iniciado'
        ELSE 'Ativo'
    END as situacao,
    COUNT(*) as quantidade,
    SUM(c.valor_total) as valor_total
FROM contratos c
JOIN tipos_contratos tc ON c.id_tipo_contrato = tc.id
GROUP BY tc.descricao,
    CASE
        WHEN c.vigencia_fim < CURRENT_DATE THEN 'Finalizado'
        WHEN c.vigencia_inicio > CURRENT_DATE THEN 'Não Iniciado'
        ELSE 'Ativo'
    END;

-- View: RCI por unidade acadêmica (ALTERADA)
CREATE VIEW vw_rci_por_unidade AS
SELECT
    ua.sigla,
    ua.nome as unidade,
    ua_pai.nome as unidade_pai,
    COUNT(DISTINCT dr.id_contrato) as total_contratos,
    SUM(dr.valor_base_calculo * dr.percentual / 100) as valor_rci_previsto,
    COALESCE(SUM(t.valor), 0) as valor_rci_recebido
FROM unidades_academicas ua
LEFT JOIN unidades_academicas ua_pai ON ua.id_unidade_pai = ua_pai.id
LEFT JOIN distribuicao_rci dr ON ua.id = dr.id_unidade
LEFT JOIN transferencias t ON t.id_distribuicao_rci = dr.id
GROUP BY ua.id, ua.sigla, ua.nome, ua_pai.nome
ORDER BY valor_rci_previsto DESC;

-- View: Hierarquia de unidades acadêmicas (NOVA)
CREATE VIEW vw_hierarquia_unidades AS
WITH RECURSIVE hierarquia AS (
    -- Unidades raiz (sem pai)
    SELECT
        id,
        nome,
        sigla,
        id_unidade_pai,
        0 as nivel,
        ARRAY[id] as caminho,
        nome::text as caminho_completo
    FROM unidades_academicas
    WHERE id_unidade_pai IS NULL

    UNION ALL

    -- Unidades filhas
    SELECT
        ua.id,
        ua.nome,
        ua.sigla,
        ua.id_unidade_pai,
        h.nivel + 1,
        h.caminho || ua.id,
        h.caminho_completo || ' > ' || ua.nome
    FROM unidades_academicas ua
    JOIN hierarquia h ON ua.id_unidade_pai = h.id
)
SELECT * FROM hierarquia
ORDER BY caminho;

COMMENT ON VIEW vw_contratos_situacao IS 'Resumo de contratos agrupados por tipo e situação';
COMMENT ON VIEW vw_rci_por_unidade IS 'Resumo de RCI previsto e recebido por unidade acadêmica';
COMMENT ON VIEW vw_hierarquia_unidades IS 'Hierarquia completa das unidades acadêmicas';

