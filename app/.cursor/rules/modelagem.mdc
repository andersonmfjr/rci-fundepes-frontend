-- =====================================================
-- VIEWS ÚTEIS PARA O DASHBOARD
-- =====================================================

-- View: Resumo de contratos por situação
CREATE VIEW vw_contratos_situacao AS
SELECT 
    tc.descricao as tipo_contrato,
    CASE 
        WHEN c.vigencia_fim < CURRENT_DATE THEN 'Finalizado'
        WHEN c.vigencia_inicio > CURRENT_DATE THEN 'Não Iniciado'
        ELSE 'Ativo'
    END as situacao,
    COUNT(*) as quantidade,
    SUM(c.valor_total) as valor_total
FROM contratos c
JOIN tipos_contratos tc ON c.id_tipo_contrato = tc.id
GROUP BY tc.descricao, 
    CASE 
        WHEN c.vigencia_fim < CURRENT_DATE THEN 'Finalizado'
        WHEN c.vigencia_inicio > CURRENT_DATE THEN 'Não Iniciado'
        ELSE 'Ativo'
    END;

-- View: RCI por unidade acadêmica
CREATE VIEW vw_rci_por_unidade AS
SELECT 
    ua.sigla,
    ua.nome as unidade,
    i.sigla as instituicao,
    COUNT(DISTINCT dr.id_contrato) as total_contratos,
    SUM(dr.valor_base_calculo * dr.percentual / 100) as valor_rci_previsto,
    COALESCE(SUM(t.valor), 0) as valor_rci_recebido
FROM unidades_academicas ua
JOIN instituicoes i ON ua.id_instituicao = i.id
LEFT JOIN distribuicao_rci dr ON ua.id = dr.id_unidade
LEFT JOIN transferencias t ON t.id_contrato = dr.id_contrato
GROUP BY ua.id, ua.sigla, ua.nome, i.sigla
ORDER BY valor_rci_previsto DESC;

COMMENT ON VIEW vw_contratos_situacao IS 'Resumo de contratos agrupados por tipo e situação';
COMMENT ON VIEW vw_rci_por_unidade IS 'Resumo de RCI previsto e recebido por unidade acadêmica';

